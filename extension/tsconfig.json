{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "paths": {
      "$sdk/*": ["../sdk/src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src", "scripts"]
}
