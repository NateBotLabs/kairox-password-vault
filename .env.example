# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (cargo run): point at your local Postgres instance
DATABASE_URL=postgres://kairox:kairox@localhost:5432/kairox

# Password for the 'kairox' Postgres user (used by docker-compose)
POSTGRES_PASSWORD=kairox

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be changed before deploying.
# Generate a strong value: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-before-deploying

# ── Server ────────────────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:3000

# Host port exposed by docker-compose (mapped to container :3000)
BIND_PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Comma-separated list of crate=level directives (uses RUST_LOG env var)
RUST_LOG=kairox_api=debug,tower_http=debug

# ── Migrations (Docker / production) ─────────────────────────────────────────
# Path to the migrations directory inside the container.
# Only set this if you are NOT using the built-in default (CARGO_MANIFEST_DIR/migrations).
# MIGRATIONS_PATH=/app/migrations
