{
  "name": "@kairox/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript SDK for kairox-password-vault — wraps the WASM crypto core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "kairox-crypto-wasm": "file:../crates/kairox-crypto/pkg"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
