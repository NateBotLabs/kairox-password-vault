# ── Rust ──────────────────────────────────────────────────────────────────────
/target
debug/
**/*.rs.bk
*.pdb
**/mutants.out*/

# ── WASM build output (regenerated by `wasm-pack build`) ──────────────────────
crates/kairox-crypto/pkg/

# ── Node / JS ─────────────────────────────────────────────────────────────────
node_modules/

# Compiled TypeScript output (regenerated by `tsc` / `vite build`)
dist/

# Vite dev-server cache
.vite/

# ── Extension (generated at build time, not source) ───────────────────────────
extension/public/wasm/
extension/public/icons/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# Root-level package-lock.json is accidental — there is no root package.json.
# Lock files inside sdk/, web/, extension/ are intentional and committed.
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
*.suo
*.user

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
CLAUDE.md
